{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth." },
        "displayName": { "type": "string", "description": "User's full name." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile picture URL." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp." }
      },
      "required": ["uid", "email"]
    },
    "Reservation": {
      "title": "Laundry Reservation",
      "description": "Stores laundry pickup and delivery requests.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "UID of the user who made the reservation." },
        "userName": { "type": "string", "description": "Name of the user." },
        "pickupDate": { "type": "string", "format": "date", "description": "Requested pickup date." },
        "address": { "type": "string", "description": "Pickup/delivery address." },
        "phone": { "type": "string", "description": "Contact phone number." },
        "status": { "type": "string", "enum": ["pending", "confirmed", "processing", "delivered"], "description": "Current status of the reservation." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Reservation timestamp." }
      },
      "required": ["uid", "pickupDate", "address", "phone"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/reservations/{reservationId}": {
      "schema": "Reservation",
      "description": "Laundry reservation documents."
    }
  }
}
